# Minimal Firecracker kernel config for aarch64
# Tested with Firecracker v1.10.1 on nested KVM
# Kernel: 4.14.x

# Base
CONFIG_64BIT=y
CONFIG_SMP=y
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_FUTEX=y
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_AIO=y
CONFIG_ADVISE_SYSCALLS=y
CONFIG_MULTIUSER=y
CONFIG_SHMEM=y
CONFIG_POSIX_TIMERS=y
CONFIG_FILE_LOCKING=y
CONFIG_DNOTIFY=y
CONFIG_INOTIFY_USER=y
CONFIG_FHANDLE=y

# ARM64 specific
CONFIG_ARM64=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_AMBA=y

# Virtio (required by Firecracker)
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y

# Vsock (host<->guest communication)
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# Filesystem
CONFIG_EXT4_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Serial console (ARM uses PL011 UART)
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# TTY / PTY (needed for exec)
CONFIG_TTY=y
CONFIG_UNIX98_PTYS=y

# Networking (minimal)
CONFIG_NET=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y

# Block layer
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# Init
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# Cgroups
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_SCHED=y
CONFIG_MEMCG=y

# No modules (everything built-in)
# CONFIG_MODULES is not set

# Disable unnecessary features
# CONFIG_WIRELESS is not set
# CONFIG_SOUND is not set
# CONFIG_USB is not set
# CONFIG_DRM is not set
# CONFIG_FB is not set
# CONFIG_SELINUX is not set
# CONFIG_SECURITY is not set
# CONFIG_AUDIT is not set
